# =============================================================================
# Water Data Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#
# When running WITH tsm-orchestration (./run_with_tsm.sh):
#   - DATABASE_URL, TIMEIO_DB_*, MINIO_URL, MQTT_BROKER_HOST are overridden
#     by docker-compose.tsm.yml — the values here are only used as fallbacks.
#   - Credentials (DB, Keycloak, MinIO, MQTT) MUST match tsm-orchestration/.env
#
# When running STANDALONE (docker compose up):
#   - All values here apply directly.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Water Data Platform
DEBUG=true
VERSION=1.0.0
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# Public hostname for frontend URLs (use 'localhost' for local dev)
PUBLIC_HOSTNAME=localhost

# -----------------------------------------------------------------------------
# Security
# @security — generate a real secret for production
# -----------------------------------------------------------------------------
SECRET_KEY=dev-secret-key-change-in-production-32chars
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Must match tsm-orchestration FERNET_ENCRYPTION_SECRET
FERNET_ENCRYPTION_SECRET=6zHUWtp8k8y9TtMLdNEp1E_ZAtgKPYw29ySdGdeg1Mo=

# NextAuth (frontend session secret)
AUTH_SECRET=dev-auth-secret-change-in-production
NEXTAUTH_SECRET=dev-auth-secret-change-in-production

# -----------------------------------------------------------------------------
# Database (standalone mode — postgres-app container)
# When using TSM, docker-compose.tsm.yml overrides DATABASE_URL → database:5432
# -----------------------------------------------------------------------------
POSTGRES_DB=water_app
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres-app:5432/water_app
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# TimeIO / TSM database connection (must match tsm-orchestration DATABASE_USER/PASSWORD)
TIMEIO_DB_HOST=database
TIMEIO_DB_PORT=5432
TIMEIO_DB_USER=postgres
TIMEIO_DB_PASSWORD=postgres
TIMEIO_DB_NAME=postgres

# -----------------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Keycloak — must match tsm-orchestration KEYCLOAK_ADMIN_USER / KEYCLOAK_ADMIN_PASS
# -----------------------------------------------------------------------------
KEYCLOAK_URL=http://keycloak:8081/keycloak
KEYCLOAK_EXTERNAL_URL=http://localhost:8081
KEYCLOAK_ADMIN_USERNAME=keycloak
KEYCLOAK_ADMIN_PASSWORD=keycloak

# -----------------------------------------------------------------------------
# MinIO / Object Storage — must match tsm-orchestration OBJECT_STORAGE_ROOT_USER/PASSWORD
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
OBJECT_STORAGE_ROOT_USER=minioadmin
OBJECT_STORAGE_ROOT_PASSWORD=minioadmin

# -----------------------------------------------------------------------------
# MQTT — must match tsm-orchestration THING_MANAGEMENT_MQTT_USER / THING_MANAGEMENT_MQTT_PASS
# -----------------------------------------------------------------------------
MQTT_USERNAME=frontendbus
MQTT_PASSWORD=frontendbus

# -----------------------------------------------------------------------------
# FROST / SensorThings API
# -----------------------------------------------------------------------------
FROST_URL=http://frost:8080

# -----------------------------------------------------------------------------
# GeoServer (set to actual GeoServer host — may be on a separate machine)
# -----------------------------------------------------------------------------
GEOSERVER_URL=http://localhost:8079/geoserver
GEOSERVER_ADMIN_USER=admin
GEOSERVER_PASSWORD=geoserver
GEOSERVER_WORKSPACE=water_data
GEOSERVER_DB_SCHEMA=water_dp_geo

# -----------------------------------------------------------------------------
# Seeding (water-dp-seed container)
# Admin user that must exist in Keycloak with full access
# -----------------------------------------------------------------------------
SEED_ADMIN_USERNAME=admin-siki
SEED_ADMIN_PASSWORD=admin-siki

# -----------------------------------------------------------------------------
# Monitoring / Observability (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
TIME_ZONE=UTC
MAX_TIME_RANGE_DAYS=365
CORS_ORIGINS=["*"]

# Admin roles (comma-separated list of Keycloak realm roles considered admin)
ADMIN_ROLES=admin
